{
    "name": "@navikt/smart-on-fhir",
    "version": "1.6.2",
    "packageManager": "yarn@4.17.0",
    "engines": {
        "node": "24"
    },
    "type": "module",
    "scripts": {
        "build": "tsdown",
        "test": "vitest",
        "tsc": "tsc",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "postinstall": "husky",
        "next:major": "yarn version -i major",
        "next:minor": "yarn version -i minor",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://npm.pkg.github.com/"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "exports": {
        "./client": {
            "types": "./dist/client/index.d.ts",
            "import": "./dist/client/index.js"
        },
        "./zod": {
            "types": "./dist/zod/index.d.ts",
            "import": "./dist/zod/index.js"
        }
    },
    "dependencies": {
        "@navikt/pino-logger": "^5.0.0",
        "@opentelemetry/api": "^1.9.1",
        "@opentelemetry/core": "^2.8.0",
        "jose": "^6.2.3",
        "openid-client": "^6.8.4",
        "quick-lru": "^7.3.0"
    },
    "peerDependencies": {
        "pino": "9 || 10",
        "zod": "4"
    },
    "devDependencies": {
        "@navikt/tsm-oxfmt": "^0.0.5",
        "@types/node": "24.13.2",
        "@vitest/coverage-v8": "4.1.8",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "nock": "^14.0.15",
        "oxfmt": "^0.54.0",
        "oxlint": "^1.69.0",
        "oxlint-tsgolint": "^0.23.0",
        "pino": "^10.3.1",
        "pinst": "^3.0.0",
        "tsdown": "^0.22.2",
        "typescript": "^6.0.3",
        "vitepress": "^1.6.4",
        "vitepress-plugin-npm-commands": "^0.10.0",
        "vitepress-plugin-tabs": "^0.9.0",
        "vitest": "^4.1.8",
        "vue": "^3.5.38",
        "zod": "^4.4.3"
    }
}
